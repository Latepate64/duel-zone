<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema">
    <xs:include schemaLocation="card.xsd" />
    <xs:include schemaLocation="race.xsd" />
    <xs:complexType name="creature">
        <xs:complexContent>
            <xs:extension base="card">
                <xs:sequence>
                    <xs:element name="races">
                        <xs:complexType>
                            <xs:sequence>
                                <xs:element name="race" type="race" minOccurs="1"
                                    maxOccurs="2" />
                            </xs:sequence>
                        </xs:complexType>
                    </xs:element>
                </xs:sequence>
                <xs:attribute name="power" type="xs:int" use="required" />
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>
</xs:schema>